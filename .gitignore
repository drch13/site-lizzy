*.log

# Ignorer les fichiers temporaires
*.tmp
*.temp

# Ignorer les fichiers de cache
.cache/

# Ignorer les images optimisées (si générées automatiquement)
/images/optimized/

# Ignorer les fichiers de configuration locale
.env
.env.local
.env.*.local
