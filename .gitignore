# Ignorer les fichiers générés ou temporaires
.DS_Store
Thumbs.db

# Ignorer les fichiers de configuration des éditeurs
.idea/
.vscode/
*.swp
*.swo

# Ignorer les fichiers de build ou de distribution
/dist/
/build/

# Ignorer les fichiers de dépendances (si on utilise npm plus tard)
/node_modules/
package-lock.json

